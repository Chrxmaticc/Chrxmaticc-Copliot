{
  "rewrites": [
    { "source": "/api/chat", "destination": "/api/chat.js" },
    { "source": "/api/memory", "destination": "/api/memory.js" },
    { "source": "/api/auth", "destination": "/api/auth.js" },
    { "source": "/api/personal", "destination": "/api/personal.js" },
    { "source": "/api/auth/discord", "destination": "/api/auth/discord/discord.js" },
    { "source": "/api/auth/discord/callback", "destination": "/api/auth/discord/callback.js" },
    { "source": "/forgot", "destination": "/public/forgot.html" },
    { "source": "/accounts", "destination": "/public/accounts.html" },
    { "source": "/settings", "destination": "/public/settings.html" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    }
  ]
}
